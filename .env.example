# Fintivi Backend - Environment Variables
# Copy this file to .env and fill in the values.
# Required variables are marked with (required).

# SQLite database file path (MVP uses SQLite for zero-infrastructure local dev)
# For enterprise PostgreSQL migration, see docker-compose.yml
DATABASE_URL=file:./data/fintivi.db

# JWT signing key for access tokens (required, min 32 characters)
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-string

# Refresh token signing key (required, min 32 characters)
REFRESH_TOKEN_SECRET=change-me-to-another-random-64-char-string

# Pepper for phone number HMAC hashing (required, min 16 characters)
PHONE_HASH_PEPPER=change-me-pepper-16

# OTP provider (required)
# Use "test" for development (OTP codes are returned in the response)
# Use "twilio" for production with Twilio
OTP_PROVIDER=test

# Google OAuth credentials (required, obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback

# Server configuration (optional)
PORT=8001
HOST=0.0.0.0
NODE_ENV=development

# Web app configuration
WEB_APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8001/api/v1
